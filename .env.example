# ---------------------------------------------------------------
# reversion_scalp_v1_aggressive — configuración de entorno
# Copiar a .env y completar los valores reales
# ---------------------------------------------------------------

# --- MODO: paper (false) o live (true) ---
LIVE_TRADING=false

# --- Credenciales Binance Futures (solo requeridas en LIVE_TRADING=true) ---
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- Límites live (solo aplican cuando LIVE_TRADING=true) ---
# Máximo de trades simultáneos en live (actualmente fijado en 1 para seguridad)
MAX_LIVE_CONCURRENT_TRADES=1
# Notional máximo por símbolo en USDT
MAX_LIVE_SYMBOL_NOTIONAL=10
